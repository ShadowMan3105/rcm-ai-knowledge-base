{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KB Revision Snapshot",
  "description": "Schema for the YAML frontmatter at the top of each revisions/*.md file. Body is the snapshot.",
  "type": "object",
  "additionalProperties": false,
  "required": ["entry_id", "revision_at", "revision_by", "change_type", "reason"],
  "properties": {
    "entry_id": {
      "type": "string",
      "pattern": "^KB-[0-9]{4}-[0-9]{4}-[a-z0-9-]+$"
    },
    "revision_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "revision_by": {
      "type": "string",
      "minLength": 2
    },
    "change_type": {
      "type": "string",
      "enum": [
        "initial",
        "migration",
        "verify",
        "authorized-edit",
        "supersede",
        "deprecate",
        "challenge-resolution"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 5
    },
    "authorized_by": {
      "type": ["string", "null"]
    }
  }
}
