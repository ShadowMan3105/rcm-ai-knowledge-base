{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KB Challenge Metadata",
  "description": "Schema for the YAML frontmatter of files in challenges/. The file body holds prose evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "challenges",
    "opened_at",
    "opened_by",
    "claim_type",
    "summary",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^CH-[0-9]{4}-[0-9]{2}-[0-9]{2}-[a-z0-9-]+$",
      "description": "Format: CH-YYYY-MM-DD-short-slug."
    },
    "challenges": {
      "type": "string",
      "pattern": "^KB-[0-9]{4}-[0-9]{4}-[a-z0-9-]+$",
      "description": "ID of the entry being challenged."
    },
    "opened_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "opened_by": {
      "type": "string",
      "minLength": 2,
      "description": "Canonical agent ID."
    },
    "claim_type": {
      "type": "string",
      "enum": [
        "incorrect",
        "obsolete",
        "incomplete",
        "ambiguous",
        "scope-creep",
        "duplicate"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500
    },
    "status": {
      "type": "string",
      "enum": ["open", "accepted", "rejected", "partial"]
    },
    "resolved_at": {
      "type": ["string", "null"],
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "resolved_by": {
      "type": ["string", "null"]
    },
    "resolution_notes": {
      "type": ["string", "null"]
    },
    "successor_entry": {
      "type": ["string", "null"],
      "description": "If accepted/partial, the new entry ID that replaces the challenged one."
    }
  }
}
